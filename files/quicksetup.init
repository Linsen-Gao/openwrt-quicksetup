#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

start_service() {
    # 仅在串口/物理终端 (tty) 上自动运行，SSH 等不触发
    # 检测当前是否为 tty1 或 ttyS0 等物理终端
    procd_open_instance
    procd_set_param command /usr/sbin/quicksetup
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger quicksetup
}
